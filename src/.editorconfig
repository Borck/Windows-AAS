##########################################
# Test File Rules
# Appended by Script to allow underscores in test names
##########################################

[**Tests.cs]
# Disable CA1707 (Identifiers should not contain underscores) for test files
dotnet_diagnostic.CA1707.severity = none

# Define naming rule for test methods to allow underscores
dotnet_naming_rule.test_methods_should_have_underscores.severity = suggestion
dotnet_naming_rule.test_methods_should_have_underscores.symbols = test_methods
dotnet_naming_rule.test_methods_should_have_underscores.style = test_method_style

# Symbol group: public methods in test files
dotnet_naming_symbols.test_methods.applicable_kinds = method
dotnet_naming_symbols.test_methods.applicable_accessibilities = public

# Naming style: PascalCase with underscores allowed as separators
dotnet_naming_style.test_method_style.capitalization = pascal_case
dotnet_naming_style.test_method_style.word_separator = _